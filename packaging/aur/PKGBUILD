# Maintainer: Samuel B <samuelb@users.noreply.github.com>
pkgname=somad
_binname=soma
pkgver=0.9.0
pkgrel=1
pkgdesc='A client for streaming SomaFM radio channels'
arch=('x86_64' 'aarch64')
url='https://github.com/samuelb/somad'
license=('MIT')
depends=('alsa-lib' 'ca-certificates')
makedepends=('go')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${pkgname}-${pkgver}"
  export CGO_ENABLED=1
  export GOFLAGS="-buildvcs=false -mod=vendor"
  go build \
    -ldflags "-s -w -X main.version=v${pkgver} -X main.commit=aur -X main.date=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    -o "${_binname}" \
    ./cmd/soma
}

check() {
  cd "${pkgname}-${pkgver}"
  export CGO_ENABLED=1
  export GOFLAGS="-buildvcs=false -mod=vendor"
  go test ./...
}

package() {
  cd "${pkgname}-${pkgver}"
  install -Dm755 "${_binname}" "${pkgdir}/usr/bin/${_binname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 cmd/soma/completions/soma.bash "${pkgdir}/usr/share/bash-completion/completions/${_binname}"
  install -Dm644 cmd/soma/completions/soma.zsh "${pkgdir}/usr/share/zsh/site-functions/_${_binname}"
}
